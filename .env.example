# Copy to .env and fill in values: cp .env.example .env
#
# API (required)
API_KEY=change-me-to-a-long-random-secret
API_LISTEN=:8080
API_PORT=8080

# SAIA / Moodle scraper (required for sync)
UTS_USERNAME=
UTS_PASSWORD=
# Optional overrides:
# SAIA_PAGE=https://saia.uft.edu.ve/
# COURSE_VIEW_BASE_URL=https://saia.uft.edu.ve/course/view.php
# CHROME_BIN=/usr/bin/chromium   # use a non-snap path on Linux (Snap breaks headless); Docker sets this

# MySQL — use host "db" when running API inside Docker Compose
DATABASE_DSN=uts:uts_pass_change_me@tcp(db:3306)/uft_db?parseTime=true&charset=utf8mb4

# Compose MySQL service (defaults match DATABASE_DSN user/pass above)
MYSQL_ROOT_PASSWORD=uts_root_change_me
MYSQL_USER=uts
MYSQL_PASSWORD=uts_pass_change_me
MYSQL_PUBLISH_PORT=3306
