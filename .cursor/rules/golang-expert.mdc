```yaml
linters:
  enable:
    - errcheck
    - gosimple
    - govet
    - ineffassign
    - staticcheck
    - unused
    - gofmt
    - goimports
    - misspell
    - revive
    - gosec
    - exhaustive

linters-settings:
  revive:
    rules:
      - name: exported
      - name: var-naming
```

